{
	"files": {
		"includes": ["src/**/*.ts", "test/**/*.ts", "*.json", "!**/node_modules/**/*"]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 120
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended",
			"complexity": {
				"useLiteralKeys": "off"
			},
			"style": {
				"noNonNullAssertion": "error",
				"useImportType": "error"
			},
			"suspicious": {
				"noExplicitAny": "error"
			}
		}
	}
}
