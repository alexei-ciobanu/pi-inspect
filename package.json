{
	"name": "pi-inspect",
	"version": "0.1.0",
	"private": true,
	"description": "Inspect Pi system prompts, tools, and model-visible tool exchanges",
	"type": "module",
	"license": "MIT",
	"homepage": "https://github.com/alexei-ciobanu/pi-inspect",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/alexei-ciobanu/pi-inspect.git"
	},
	"keywords": [
		"pi-package",
		"pi-coding-agent",
		"debugging",
		"inspection"
	],
	"pi": {
		"extensions": [
			"./src/index.ts"
		]
	},
	"scripts": {
		"test": "vitest run",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"check": "tsc --noEmit && biome check . && vitest run"
	},
	"peerDependencies": {
		"@earendil-works/pi-coding-agent": "*",
		"@earendil-works/pi-tui": "*"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.2",
		"@earendil-works/pi-coding-agent": "^0.80.6",
		"@earendil-works/pi-tui": "^0.80.6",
		"@types/node": "^24.0.0",
		"typescript": "^6.0.0",
		"vitest": "^4.0.0"
	},
	"engines": {
		"node": ">=22.0.0"
	}
}
